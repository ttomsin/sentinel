[55.079027, "o", "\r\n\u001b[?2004l\r"]
[55.083579, "o", "\r\n\u001b[1m  SENTINEL STATUS\u001b[22m\r\n\r\n\r\n\u001b[1m  SENTINEL STATUS\u001b[22m\r\n\r\n\u001b[36m  Core Protection (Active):\u001b[0m\r\n\u001b[32m    ✓  PREVENT   AES-256-GCM encryption — AI scrapers see only noise\u001b[0m\r\n\u001b[32m    ✓  PROVE     SHA-256 hashing — every file fingerprinted per commit\u001b[0m\r\n\u001b[32m    ✓  CHAIN     OpenTimestamps — root hash anchored to Bitcoin (free)\u001b[0m\r\n\u001b[32m    ✓  DETECT    AI interrogation — similarity scanning across 4 providers\u001b[0m\r\n\u001b[32m    ✓  ACCESS    HKDF key derivation — collaborator grant/revoke system\u001b[0m\r\n\u001b[32m    ✓  OPEN      --proof-only mode — proof without encryption for open source\u001b[0m\r\n\r\n\u001b[36m  Coming Next:\u001b[0m\r\n\u001b[33m    ◌  LANGUAGES  Multi-language AST support (JS, Python, Rust, Java)\u001b[0m\r\n\u001b[33m    ◌  HUB        Sentinel Hub — self-hostable team dashboard\u001b[0m\r\n\u001b[33m    ◌  LEGAL      Court-ready PDF evidence report generator\u001b[0m\r\n\u001b[33m    ◌  KEYS       QR code / local network key exchange\u001b[0m\r\n\u001b[33m    ◌  REGISTRY   npm, PyPI, crates.io package protection\u001b[0m\r\n\r\n\u001b[90m  Open source — contributions welcome:\u001b[0m\r\n\u001b[90m  https://github.com/ttomsin/sentinel\u001b[0m\r\n\r\n\u001b[36m  Git Status:\u001b[0m\r\n"]
[55.088666, "o", "On branch main\r\nYour branch is ahead of 'origin/main' by 2 commits.\r\n  (use \"git push\" to publish your local commits)\r\n\r\nChanges not staged for commit:\r\n  (use \"git add <file>...\" to update what will be committed)\r\n  (use \"git restore <file>...\" to discard changes in working directory)\r\n\tmodified:   .sentinel/proofs/index.json\r\n\tmodified:   sentinel-demo.cast\r\n\r\nUntracked files:\r\n  (use \"git add <file>...\" to include in what will be committed)\r\n\t.sentinel/hashes/1773952302.json\r\n\t.sentinel/proofs/105d7cd6b68949f3.ots\r\n\r\nno changes added to commit (use \"git add\" and/or \"git commit -a\")\r\n"]
